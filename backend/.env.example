# =====================================================
# VARIABLES DE ENTORNO - EL RINCONCITO BACKEND
# =====================================================
# Copia este archivo como .env.development (local) o configura estas variables
# en tu plataforma de deployment (Render, Railway, etc.)

# ===================
# ENTORNO
# ===================
NODE_ENV=production
PORT=3000

# ===================
# SUPABASE
# ===================
# Obtén estos valores de: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-supabase-anon-key-aqui

# ===================
# TWILIO
# ===================
# Obtén estos valores de: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu-twilio-auth-token-aqui
TWILIO_PHONE_NUMBER=+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Número de WhatsApp para el bot (sandbox o producción)
TWILIO_WHATSAPP_CLIENTES=whatsapp:+14155238886

# ===================
# ADMINISTRADOR
# ===================
# Número de teléfono del administrador (con formato internacional)
# Recibirá notificaciones de nuevos pedidos y errores críticos por WhatsApp
# Ejemplo para México: +5215512345678
# ⚠️ OBLIGATORIO - El sistema no funcionará sin este número
ADMIN_PHONE_NUMBER=+525636399034

# Número secundario de respaldo (opcional pero recomendado)
# Si el primario falla, el sistema intentará este número automáticamente
ADMIN_PHONE_NUMBER_SECONDARY=

# ===================
# CORS
# ===================
# URLs permitidas para hacer requests (separadas por coma)
# Ejemplo: https://tu-app.netlify.app,https://otro-dominio.com
FRONTEND_URL=http://localhost:5173

# ===================
# SEGURIDAD
# ===================
# 🔒 JWT - Autenticación
# Genera una clave secreta aleatoria en: https://randomkeygen.com/
# O ejecuta: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-clave-secreta-aleatoria-de-64-caracteres-minimo
JWT_EXPIRES_IN=24h

# 🔐 Credenciales de Admin
# Usuario para login del dashboard
ADMIN_USERNAME=admin

# Hash bcrypt del password del admin
# Para generar el hash en desarrollo:
# 1. Inicia el servidor
# 2. POST http://localhost:3000/api/auth/hash-password
#    Body: { "password": "tu-password-seguro" }
# 3. Copia el hash generado aquí
# ⚠️ NUNCA pongas el password en texto plano aquí
ADMIN_PASSWORD_HASH=$2a$10$ejemplo.hash.bcrypt.aqui.reemplazalo

# ===================
# LOGS
# ===================
LOG_LEVEL=info

# ===================
# REDIS (SESIONES)
# ===================
# Redis para gestión de sesiones en producción (recomendado para escalabilidad)
# Deja vacío para usar memoria (solo desarrollo)
# Ejemplo: redis://default:password@redis-host:6379
REDIS_URL=
REDIS_ENABLED=false

# ===================
# MENSAJERÍA (OPCIONAL)
# ===================
# Modo de prueba: No envía mensajes reales de WhatsApp (ahorra saldo de Twilio)
# Útil para desarrollo y pruebas
TWILIO_TEST_MODE=false

# Habilitar recordatorios automáticos de pedidos pendientes
# Si está en 'false', no se enviarán recordatorios cada 2 minutos
ENABLE_REMINDERS=false
